{
  "name": "stretto-assembly",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:stretto": "npx esbuild tests/stretto.chain8.test.ts --bundle --platform=node --format=esm --outfile=.tmp/stretto.chain8.test.mjs && node .tmp/stretto.chain8.test.mjs && npx esbuild tests/stretto.arpeggio-guaranteed.test.ts --bundle --platform=node --format=esm --outfile=.tmp/stretto.arpeggio-guaranteed.test.mjs && node .tmp/stretto.arpeggio-guaranteed.test.mjs",
    "test:stretto:report": "npx esbuild scripts/generate-stretto-chain8-report.mjs --bundle --platform=node --format=esm --outfile=.tmp/generate-stretto-chain8-report.mjs && node .tmp/generate-stretto-chain8-report.mjs",
    "test:stretto:guaranteed": "npx esbuild tests/stretto.arpeggio-guaranteed.test.ts --bundle --platform=node --format=esm --outfile=.tmp/stretto.arpeggio-guaranteed.test.mjs && node .tmp/stretto.arpeggio-guaranteed.test.mjs"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@tonejs/midi": "2.0.28",
    "tone": "14.7.77",
    "@google/genai": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
